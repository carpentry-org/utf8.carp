(load "Test.carp")

(load "utf8.carp")

(use-all Test UTF8)

(sig bytes (Fn [(Ref (Array Int))] (Array Byte)))
(defn bytes [ns] (Array.copy-map &(fn [n] (Byte.from-int @n)) ns))

(defn main []
  (with-test test
    (assert-equal test
      "höy"
      &(UTF8.str &(from-string "höy"))
      "conversion to and from strings works")
    (assert-equal test
      2
      (UTF8.length &(from-string "äö"))
      "UTF-8 length works")
    (assert-equal test
      "(Just ä)"
      &(str &(nth &(from-string "ööäö") 2))
      "UTF-8 indexing works I")
    (assert-equal test
      &(Maybe.Nothing)
      &(nth &(from-string "") 2)
      "UTF-8 indexing works II")
    (assert-equal test
      "ä"
      &(str &(unsafe-nth &(from-string "ööäö") 2))
      "UTF-8 unsafe indexing works")
    (assert-equal test
      "äÖ"
      &(str &(UTF8.append &(from-string "ä") &(from-string "Ö")))
      "UTF-8 appending works")
    (assert-equal test
      "ölüp"
      &(str &(UTF8.reverse &(from-string "pülö")))
      "UTF-8 reversing works")
    (assert-equal test
      true
      (UTF8.empty? &(from-string ""))
      "UTF-8 empty check works I")
    (assert-equal test
      false
      (UTF8.empty? &(from-string "a"))
      "UTF-8 empty check works II")
    (assert-equal test
      "rüm"
      &(str &(UTF8.slice &(from-string "perümpor") 2 5))
      "UTF-8 slice works")
    (assert-equal test
      "rüm"
      &(str &(UTF8.suffix &(from-string "perüm") 2))
      "UTF-8 suffix works")
    (assert-equal test
      "perüm"
      &(str &(UTF8.suffix &(from-string "perüm") 0))
      "UTF-8 suffix from index 0 is the whole string")
    (assert-equal test
      ""
      &(str &(UTF8.suffix &(from-string "perüm") 5))
      "UTF-8 suffix from the length is empty")
    (assert-equal test
      "rüm"
      &(str &(UTF8.prefix &(from-string "rümpor") 3))
      "UTF-8 prefix works")
    (assert-equal test "" &(str &(UTF8.zero)) "UTF-8 zero works")
    (assert-equal test
      true
      (UTF8.starts-with? &(UTF8.from-string "ölämpö")
                         &(UTF8.from-string "öläm"))
      "UTF-8 starts-with check works")
    (assert-equal test
      true
      (UTF8.ends-with? &(UTF8.from-string "pööläm")
                       &(UTF8.from-string "öläm"))
      "UTF-8 ends-with check works")
    ; valid? — well-formed UTF-8 (RFC 3629), byte-level
    (assert-true test
      (UTF8.valid? &(the (Array Byte) []))
      "valid? accepts the empty string")
    (assert-true test
      (UTF8.valid? &(the (Array Byte) [(Byte.from-int 104) (Byte.from-int 105)]))
      "valid? accepts ASCII")
    (assert-true test
      (UTF8.valid? &(the (Array Byte) [(Byte.from-int 194) (Byte.from-int 169)]))
      "valid? accepts a 2-byte sequence (U+00A9)")
    (assert-true test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 226) (Byte.from-int 130) (Byte.from-int 172)]))
      "valid? accepts a 3-byte sequence (U+20AC)")
    (assert-true test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 240)
               (Byte.from-int 159)
               (Byte.from-int 152)
               (Byte.from-int 128)]))
      "valid? accepts a 4-byte sequence (U+1F600)")
    (assert-true test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 240)
               (Byte.from-int 144)
               (Byte.from-int 128)
               (Byte.from-int 128)]))
      "valid? accepts the minimal 4-byte code point (U+10000)")
    (assert-true test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 244)
               (Byte.from-int 143)
               (Byte.from-int 191)
               (Byte.from-int 191)]))
      "valid? accepts the maximal code point (U+10FFFF)")
    (assert-true test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 237) (Byte.from-int 159) (Byte.from-int 191)]))
      "valid? accepts U+D7FF, just below the surrogate range")
    (assert-true test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 238) (Byte.from-int 128) (Byte.from-int 128)]))
      "valid? accepts U+E000, just above the surrogate range")
    (assert-false test
      (UTF8.valid? &(the (Array Byte) [(Byte.from-int 192) (Byte.from-int 128)]))
      "valid? rejects an overlong 2-byte encoding (C0 80)")
    (assert-false test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 224) (Byte.from-int 159) (Byte.from-int 191)]))
      "valid? rejects an overlong 3-byte encoding (E0 9F BF)")
    (assert-false test
      (UTF8.valid? &(the (Array Byte) [(Byte.from-int 128)]))
      "valid? rejects a lone continuation byte (80)")
    (assert-false test
      (UTF8.valid? &(the (Array Byte) [(Byte.from-int 194)]))
      "valid? rejects a truncated sequence (C2)")
    (assert-false test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 237) (Byte.from-int 160) (Byte.from-int 128)]))
      "valid? rejects a low surrogate code point (ED A0 80, U+D800)")
    (assert-false test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 237) (Byte.from-int 191) (Byte.from-int 191)]))
      "valid? rejects a high surrogate code point (ED BF BF, U+DFFF)")
    (assert-false test
      (UTF8.valid?
        &(the (Array Byte)
              [(Byte.from-int 244)
               (Byte.from-int 144)
               (Byte.from-int 128)
               (Byte.from-int 128)]))
      "valid? rejects a code point above U+10FFFF (F4 90 80 80)")
    (assert-false test
      (UTF8.valid? &(the (Array Byte) [(Byte.from-int 245)]))
      "valid? rejects an out-of-range lead byte (F5)")
    (assert-false test
      (UTF8.valid? &(the (Array Byte) [(Byte.from-int 255)]))
      "valid? rejects a bare 0xFF byte")
    ; regression: characters whose codepoint low byte is 0x80..0xBF (Greek,
    ; U+0080..U+00BF, ...) used to be merged into the preceding rune, so
    ; length/nth/reverse were all off. (ä/ö/ü happen to avoid it.)
    (assert-equal test
      5
      (UTF8.length &(from-string "hεllö"))
      "UTF-8 length counts Greek runes (the doc example)")
    (assert-equal test
      "ε"
      &(str &(unsafe-nth &(from-string "hεllö") 1))
      "UTF-8 indexing finds a Greek rune")
    (assert-equal test
      "öllεh"
      &(str &(UTF8.reverse &(from-string "hεllö")))
      "UTF-8 reversing keeps Greek runes intact")
    (assert-equal test
      5
      (UTF8.length &(from-string "λόγος"))
      "UTF-8 length counts an all-Greek word")
    ; --- from-bytes: validating constructor over raw, possibly untrusted bytes ---
    (assert-equal test
      "hεllö"
      &(match (from-bytes &(String.to-bytes "hεllö"))
        (Maybe.Just u) (str &u)
        (Maybe.Nothing) @"INVALID")
      "from-bytes accepts well-formed UTF-8 and round-trips it")
    (assert-true test
      (Maybe.just? &(from-bytes &(String.to-bytes "")))
      "from-bytes accepts empty input as valid UTF-8")
    (assert-true test
      (Maybe.nothing? &(from-bytes &[(Byte.from-int 128)]))
      "from-bytes rejects a lone continuation byte")
    (assert-true test
      (Maybe.nothing? &(from-bytes &[(Byte.from-int 192) (Byte.from-int 128)]))
      "from-bytes rejects an overlong encoding")
    (assert-true test
      (Maybe.nothing?
        &(from-bytes
          &[(Byte.from-int 237) (Byte.from-int 160) (Byte.from-int 128)]))
      "from-bytes rejects a UTF-16 surrogate code point")
    (assert-true test
      (Maybe.nothing? &(from-bytes &[(Byte.from-int 195)]))
      "from-bytes rejects a truncated multibyte sequence")
    (assert-true test
      (Maybe.nothing?
        &(from-bytes
          &[(Byte.from-int 245)
            (Byte.from-int 128)
            (Byte.from-int 128)
            (Byte.from-int 128)]))
      "from-bytes rejects a code point beyond U+10FFFF")
    ; decode-at — incremental single-code-point decoder
    (assert-equal test
      &(Maybe.Just (Pair.init 0 1))
      &(decode-at &(bytes &[65 0 66]) 1)
      "decode-at reads an embedded NUL as the one-byte code point U+0000")
    (assert-equal test
      &(Maybe.Just (Pair.init 127 1))
      &(decode-at &(bytes &[127]) 0)
      "decode-at U+007F is the maximal one-byte code point (width 1)")
    (assert-equal test
      &(Maybe.Just (Pair.init 128 2))
      &(decode-at &(bytes &[194 128]) 0)
      "decode-at U+0080 is the minimal two-byte code point (width 2)")
    (assert-equal test
      &(Maybe.Just (Pair.init 2047 2))
      &(decode-at &(bytes &[223 191]) 0)
      "decode-at U+07FF is the maximal two-byte code point (width 2)")
    (assert-equal test
      &(Maybe.Just (Pair.init 2048 3))
      &(decode-at &(bytes &[224 160 128]) 0)
      "decode-at U+0800 is the minimal three-byte code point (width 3)")
    (assert-equal test
      &(Maybe.Just (Pair.init 65535 3))
      &(decode-at &(bytes &[239 191 191]) 0)
      "decode-at U+FFFF is the maximal three-byte code point (width 3)")
    (assert-equal test
      &(Maybe.Just (Pair.init 65536 4))
      &(decode-at &(bytes &[240 144 128 128]) 0)
      "decode-at U+10000 is the minimal four-byte code point (width 4)")
    (assert-equal test
      &(Maybe.Just (Pair.init 1114111 4))
      &(decode-at &(bytes &[244 143 191 191]) 0)
      "decode-at U+10FFFF is the maximal code point (width 4)")
    (assert-equal test
      &(Maybe.Just (Pair.init 55295 3))
      &(decode-at &(bytes &[237 159 191]) 0)
      "decode-at U+D7FF just below the surrogate hole is accepted")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[237 160 128]) 0)
      "decode-at rejects the low surrogate U+D800")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[237 191 191]) 0)
      "decode-at rejects the high surrogate U+DFFF")
    (assert-equal test
      &(Maybe.Just (Pair.init 57344 3))
      &(decode-at &(bytes &[238 128 128]) 0)
      "decode-at U+E000 just above the surrogate hole is accepted")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[192 128]) 0)
      "decode-at rejects an overlong two-byte encoding (C0 80)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[224 128 128]) 0)
      "decode-at rejects an overlong three-byte encoding (E0 80 80)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[240 128 128 128]) 0)
      "decode-at rejects an overlong four-byte encoding (F0 80 80 80)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[194]) 0)
      "decode-at rejects a truncated two-byte sequence (C2)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[224 160]) 0)
      "decode-at rejects a truncated three-byte sequence (E0 A0)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[240 144 128]) 0)
      "decode-at rejects a truncated four-byte sequence (F0 90 80)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[128]) 0)
      "decode-at rejects a lone continuation byte (80)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[191]) 0)
      "decode-at rejects a lone continuation byte (BF)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[245 128 128 128]) 0)
      "decode-at rejects a code point above U+10FFFF (F5 80 80 80)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[245]) 0)
      "decode-at rejects an out-of-range lead byte (F5)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[248]) 0)
      "decode-at rejects an out-of-range lead byte (F8)")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[255]) 0)
      "decode-at rejects a bare 0xFF byte")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(the (Array Byte) []) 0)
      "decode-at returns Nothing at the start of an empty buffer")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[65]) 1)
      "decode-at returns Nothing when pos is at the end of the buffer")
    (assert-equal test
      &(the (Maybe (Pair Int Int)) (Maybe.Nothing))
      &(decode-at &(bytes &[65]) -1)
      "decode-at returns Nothing for a negative offset")
    (assert-equal test
      &(Maybe.Just (Pair.init 65 1))
      &(decode-at &(bytes &[65 206 181]) 0)
      "decode-at decodes the ASCII code point at offset 0 of a mixed buffer")
    (assert-equal test
      &(Maybe.Just (Pair.init 949 2))
      &(decode-at &(bytes &[65 206 181]) 1)
      "decode-at decodes the multibyte code point at a non-zero offset")))
